# Groq API key — used for AI slide generation (free tier, fast).
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# Supabase — project URL and keys (for future server-side deck operations).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini API key — alternative AI provider (optional).
# Get yours at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-key-here

# Optional: restrict CORS to your frontend (default allows all in dev).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
