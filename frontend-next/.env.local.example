# Groq API key — REQUIRED for AI slide generation.
# Get a free key at https://console.groq.com/keys
# Add this in Vercel → Project Settings → Environment Variables too.
GROQ_API_KEY=your-groq-key-here

# Optional: point at the standalone Python backend instead of the built-in
# Next.js API route. Leave unset to use the default Next.js route.
# NEXT_PUBLIC_API_URL=http://localhost:8001
