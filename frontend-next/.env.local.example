# Groq API key — REQUIRED for AI slide generation.
# Get a free key at https://console.groq.com/keys
# Add this in Vercel → Project Settings → Environment Variables too.
GROQ_API_KEY=your-groq-key-here

# Supabase — REQUIRED for auth and deck history.
# Create a project at https://supabase.com/dashboard
# Run supabase/migrations/001_create_decks.sql in SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: for create-test-user script to create pre-confirmed demo user
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: point at the standalone Python backend instead of the built-in
# Next.js API route. Leave unset to use the default Next.js route.
# Point at standalone Python backend (optional). Leave unset to use Next.js API routes.
# NEXT_PUBLIC_API_URL=http://localhost:8001
